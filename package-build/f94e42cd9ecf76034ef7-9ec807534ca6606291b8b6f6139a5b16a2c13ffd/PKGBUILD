pkgname=basics
pkgver=1
pkgrel=1
pkgdesc="Meta-package + installer for Zenities Hyprland daily driver setup"
arch=('x86_64')
url="https://github.com/akshajtiwari/basics-meta"
license=('GPL')
install=basics.install

depends=(
  'base-devel'
  'linux-firmware'
  'kitty' 'lf' 'neovim' 'git'
  'brave-bin' 'zen-browser-bin'
  'hyprland' 'xdg-desktop-portal-hyprland' 'waybar'
  'zsh' 'starship'
  'networkmanager' 'blueman' 'cups'
  'flatpak'
  'sddm' 'plasma-desktop'
)

package() {
  install -Dm644 /dev/null "$pkgdir/usr/share/$pkgname/.placeholder"
}
